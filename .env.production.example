# Production environment template
# Скопируйте в .env на сервере и заполните значения

# NextAuth / Auth.js
AUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=https://toykhana.ru

# PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/medrese?sslmode=require

# Маркер prod-БД: demo/e2e seed (pnpm db:seed) заблокированы при совпадении с DATABASE_URL
PRODUCTION_DATABASE_URL=postgresql://user:password@host:5432/medrese?sslmode=require

# Первичный супер-админ (pnpm db:seed:prod)
# 6-значный код входа в приложение
SUPER_ADMIN_CODE=100001

# Web Push VAPID (опционально)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# S3 / объектное хранилище (рекомендуется на проде)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
S3_BUCKET=
# Публичный URL для отдачи файлов (CDN или https://bucket.s3.region.amazonaws.com)
S3_PUBLIC_URL=
# Кастомный endpoint для MinIO, Cloudflare R2 и т.п. (опционально)
# S3_ENDPOINT=
# Префикс ключей в бакете (по умолчанию uploads)
# S3_PREFIX=uploads
