generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  MANAGER
  TEACHER
  STUDENT
}

enum Attendance {
  PRESENT
  LATE
  ABSENT
}

enum AwardType {
  STUDY
  ACTIVITY
}

enum StudentStatus {
  ACTIVE
  PAUSE
  ARCHIVE
}

enum LeaveRequestType {
  VACATION
  DAY_OFF
  SICK_LEAVE
}

enum LeaveRequestStatus {
  CREATED
  APPROVED
  REJECTED
}

enum NotificationType {
  LEAVE_REQUEST_CREATED
  LEAVE_REQUEST_APPROVED
  LEAVE_REQUEST_REJECTED
  SUBSTITUTION_ACTIVATED
}

model User {
  id                         String             @id @default(cuid())
  name                       String
  code                       String             @unique
  role                       Role
  phone                      String?
  teacher                    Teacher?
  student                    Student?
  notifications              Notification[]
  pushSubscriptions          PushSubscription[]
  conversationsAsParticipant1 Conversation[]    @relation("ConversationParticipant1")
  conversationsAsParticipant2 Conversation[]    @relation("ConversationParticipant2")
  sentMessages               Message[]
  createdAt                  DateTime           @default(now())
}

model Teacher {
  id                         String            @id @default(cuid())
  userId                     String            @unique
  user                       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  groups                     Group[]
  teachingSessions           TeachingSession[]
  leaveRequests              LeaveRequest[]    @relation("LeaveRequestTeacher")
  leaveRequestsAsSubstitute  LeaveRequest[]    @relation("LeaveRequestSubstitute")
  substitutionsAsAbsent      Substitution[]    @relation("SubstitutionAbsent")
  substitutionsAsSubstitute  Substitution[]    @relation("SubstitutionSubstitute")
}

model Group {
  id               String            @id @default(cuid())
  name             String
  teacherId        String
  teacher          Teacher           @relation(fields: [teacherId], references: [id])
  students         Student[]
  teachingSessions TeachingSession[]
}

model Student {
  id             String           @id @default(cuid())
  userId         String           @unique
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName       String?
  phone          String?
  guardianPhone  String?
  groupId        String
  group          Group            @relation(fields: [groupId], references: [id])
  levelId        String
  level          Level            @relation(fields: [levelId], references: [id])
  currentStepIdx Int              @default(0)
  status         StudentStatus    @default(ACTIVE)
  sessions       Session[]
  completions    StepCompletion[]
  awards         Award[]
}

model Level {
  id       String    @id @default(cuid())
  number   Int       @unique
  title    String
  students Student[]
  steps    Step[]
}

model Step {
  id          String           @id @default(cuid())
  levelId     String
  level       Level            @relation(fields: [levelId], references: [id], onDelete: Cascade)
  order       Int
  title       String
  content     Json
  description String           @default("")
  hours       Int
  completions StepCompletion[]

  @@unique([levelId, order])
}

model Session {
  id            String           @id @default(cuid())
  studentId     String
  student       Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date          DateTime
  attendance    Attendance
  lateMinutes   Int?
  note          String?
  isAdjustment  Boolean          @default(false)
  completions   StepCompletion[]
  createdAt     DateTime         @default(now())
}

model StepCompletion {
  id            String   @id @default(cuid())
  studentId     String
  stepId        String
  sessionId     String
  grade         Int
  note          String?
  isPriorCredit Boolean  @default(false)
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  step          Step     @relation(fields: [stepId], references: [id])
  session       Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
}

model Award {
  id        String    @id @default(cuid())
  studentId String
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type      AwardType
  title     String
  date      DateTime  @default(now())
}

model TeachingSession {
  id        String    @id @default(cuid())
  teacherId String
  teacher   Teacher   @relation(fields: [teacherId], references: [id])
  groupId   String
  group     Group     @relation(fields: [groupId], references: [id])
  date      DateTime
  startedAt DateTime
  endedAt   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([teacherId, date])
  @@index([groupId, date])
}

model AuditEvent {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  entityType String
  entityId   String
  payload    Json
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([entityType, entityId])
}

model LeaveRequest {
  id                  String             @id @default(cuid())
  teacherId           String
  teacher             Teacher            @relation("LeaveRequestTeacher", fields: [teacherId], references: [id])
  type                LeaveRequestType
  status              LeaveRequestStatus @default(CREATED)
  startDate           DateTime
  endDate             DateTime
  description         String
  rejectionReason     String?
  substituteTeacherId String?
  substituteTeacher   Teacher?           @relation("LeaveRequestSubstitute", fields: [substituteTeacherId], references: [id])
  substitutionId      String?            @unique
  substitution        Substitution?      @relation(fields: [substitutionId], references: [id])
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([teacherId, status])
  @@index([startDate, endDate])
}

model Substitution {
  id                  String   @id @default(cuid())
  absentTeacherId     String
  absentTeacher       Teacher  @relation("SubstitutionAbsent", fields: [absentTeacherId], references: [id])
  substituteTeacherId String
  substituteTeacher   Teacher  @relation("SubstitutionSubstitute", fields: [substituteTeacherId], references: [id])
  leaveRequestId      String?       @unique
  leaveRequest        LeaveRequest?
  startDate           DateTime
  endDate             DateTime
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([substituteTeacherId, isActive])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  link      String?
  payload   Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Conversation {
  id             String    @id @default(cuid())
  participant1Id String
  participant2Id String
  participant1   User      @relation("ConversationParticipant1", fields: [participant1Id], references: [id], onDelete: Cascade)
  participant2   User      @relation("ConversationParticipant2", fields: [participant2Id], references: [id], onDelete: Cascade)
  messages       Message[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([participant1Id, participant2Id])
  @@index([participant1Id])
  @@index([participant2Id])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body           String
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}
