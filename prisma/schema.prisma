generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  MANAGER
  TEACHER
  STUDENT
  ACCOUNTANT
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

enum ExpenseCategory {
  SUPPLIES
  UTILITIES
  RENT
  OTHER
}

enum SalaryAccrualStatus {
  DRAFT
  CONFIRMED
  PAID
}

enum Attendance {
  PRESENT
  LATE
  ABSENT
}

enum AwardType {
  STUDY
  ACTIVITY
}

enum StudentStatus {
  ACTIVE
  PAUSE
  ARCHIVE
}

enum LeaveRequestType {
  VACATION
  DAY_OFF
  SICK_LEAVE
}

enum LeaveRequestStatus {
  CREATED
  APPROVED
  REJECTED
}

enum NotificationType {
  LEAVE_REQUEST_CREATED
  LEAVE_REQUEST_APPROVED
  LEAVE_REQUEST_REJECTED
  SUBSTITUTION_ACTIVATED
  MESSAGE_RECEIVED
  POST_PUBLISHED
}

enum PostMediaType {
  IMAGE
  VIDEO
}

model User {
  id                         String             @id @default(cuid())
  name                       String
  code                       String             @unique
  role                       Role
  phone                      String?
  teacher                    Teacher?
  student                    Student?
  notifications              Notification[]
  pushSubscriptions          PushSubscription[]
  conversationsAsParticipant1 Conversation[]    @relation("ConversationParticipant1")
  conversationsAsParticipant2 Conversation[]    @relation("ConversationParticipant2")
  sentMessages               Message[]
  tuitionPaymentsCreated     TuitionPayment[]   @relation("TuitionPaymentCreatedBy")
  expensesCreated            Expense[]          @relation("ExpenseCreatedBy")
  donationsCreated           Donation[]         @relation("DonationCreatedBy")
  salaryPayoutsCreated       SalaryPayout[]     @relation("SalaryPayoutCreatedBy")
  monthClosesCreated         MonthClose[]       @relation("MonthCloseCreatedBy")
  sessionDurationAdjustments TeachingSessionDurationAdjustment[] @relation("SessionDurationAdjustedBy")
  extraAssignmentsAuthored   ExtraAssignment[]
  extraAssignmentsAssigned   StudentExtraAssignment[]            @relation("ExtraAssignmentAssignedBy")
  postsAuthored              Post[]
  postLikes                  PostLike[]
  createdAt                  DateTime           @default(now())
}

model Teacher {
  id                         String            @id @default(cuid())
  userId                     String            @unique
  user                       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  groups                     Group[]
  teachingSessions           TeachingSession[]
  leaveRequests              LeaveRequest[]    @relation("LeaveRequestTeacher")
  leaveRequestsAsSubstitute  LeaveRequest[]    @relation("LeaveRequestSubstitute")
  substitutionsAsAbsent      Substitution[]    @relation("SubstitutionAbsent")
  substitutionsAsSubstitute  Substitution[]    @relation("SubstitutionSubstitute")
  teacherRates               TeacherRate[]
  salaryAccruals             SalaryAccrual[]
}

model Group {
  id               String            @id @default(cuid())
  name             String
  subjectId        String
  subject          Subject           @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  teacherId        String
  teacher          Teacher           @relation(fields: [teacherId], references: [id])
  enrollments      GroupEnrollment[]
  sessions         Session[]
  teachingSessions TeachingSession[]

  @@index([subjectId])
}

model GroupEnrollment {
  id              String   @id @default(cuid())
  studentId       String
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  groupId         String
  group           Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  levelId         String
  level           Level    @relation(fields: [levelId], references: [id], onDelete: Restrict)
  currentStepIdx  Int      @default(0)
  enrolledAt      DateTime @default(now())

  @@unique([studentId, groupId])
  @@index([groupId])
  @@index([studentId])
}

model Student {
  id             String           @id @default(cuid())
  userId         String           @unique
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName       String?
  phone          String?
  guardianName   String?
  guardianPhone  String?
  enrollments    GroupEnrollment[]
  status         StudentStatus    @default(ACTIVE)
  tuitionRate    Int              @default(200000)
  discountReason String?
  sessions       Session[]
  completions    StepCompletion[]
  awards         Award[]
  tuitionCharges TuitionCharge[]
  tuitionPayments TuitionPayment[]
  extraAssignments StudentExtraAssignment[]
}

model Subject {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  levels      Level[]
  groups      Group[]
}

model Level {
  id        String    @id @default(cuid())
  subjectId String
  subject   Subject   @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  number       Int
  title        String
  enrollments  GroupEnrollment[]
  steps        Step[]

  @@unique([subjectId, number])
  @@index([subjectId])
}

model Step {
  id          String           @id @default(cuid())
  levelId     String
  level       Level            @relation(fields: [levelId], references: [id], onDelete: Cascade)
  order       Int
  title       String
  content     Json
  teacherNote Json             @default("{\"blocks\":[]}")
  description String           @default("")
  hours       Int
  completions StepCompletion[]
  extraAssignments       ExtraAssignment[]
  displayExtraAssignments StudentExtraAssignment[] @relation("DisplayStepExtraAssignments")

  @@unique([levelId, order])
}

model Session {
  id            String           @id @default(cuid())
  studentId     String
  student       Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  groupId       String
  group         Group            @relation(fields: [groupId], references: [id], onDelete: Restrict)
  date          DateTime
  attendance    Attendance
  lateMinutes   Int?
  note          String?
  isAdjustment  Boolean          @default(false)
  completions   StepCompletion[]
  extraAssignments StudentExtraAssignment[]
  createdAt     DateTime         @default(now())

  @@unique([studentId, date, groupId])
  @@index([groupId, date])
}

model ExtraAssignment {
  id        String   @id @default(cuid())
  title     String
  content   Json
  stepId    String?
  step      Step?    @relation(fields: [stepId], references: [id], onDelete: SetNull)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  instances StudentExtraAssignment[]

  @@index([authorId])
  @@index([stepId])
}

model StudentExtraAssignment {
  id            String   @id @default(cuid())
  templateId    String
  template      ExtraAssignment @relation(fields: [templateId], references: [id], onDelete: Cascade)
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sessionId     String
  session       Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  displayStepId String
  displayStep   Step     @relation("DisplayStepExtraAssignments", fields: [displayStepId], references: [id])
  assignedById  String
  assignedBy    User     @relation("ExtraAssignmentAssignedBy", fields: [assignedById], references: [id])
  createdAt     DateTime @default(now())
  completion    ExtraAssignmentCompletion?

  @@index([sessionId, displayStepId])
  @@index([studentId])
}

model ExtraAssignmentCompletion {
  id                       String                 @id @default(cuid())
  studentExtraAssignmentId String                 @unique
  studentExtraAssignment   StudentExtraAssignment @relation(fields: [studentExtraAssignmentId], references: [id], onDelete: Cascade)
  grade                    Int
  note                     String?
  gradedAt                 DateTime               @default(now())
  createdAt                DateTime               @default(now())
}

model StepCompletion {
  id            String   @id @default(cuid())
  studentId     String
  stepId        String
  sessionId     String
  grade         Int
  note          String?
  isPriorCredit Boolean  @default(false)
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  step          Step     @relation(fields: [stepId], references: [id])
  session       Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
}

model Award {
  id        String    @id @default(cuid())
  studentId String
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type      AwardType
  title     String
  date      DateTime  @default(now())
}

model TeachingSession {
  id        String    @id @default(cuid())
  teacherId String
  teacher   Teacher   @relation(fields: [teacherId], references: [id])
  groupId   String
  group     Group     @relation(fields: [groupId], references: [id])
  date      DateTime
  startedAt DateTime
  endedAt   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  durationAdjustment TeachingSessionDurationAdjustment?

  @@index([teacherId, date])
  @@index([groupId, date])
}

model TuitionCharge {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  month     String
  amount    Int
  createdAt DateTime @default(now())

  @@unique([studentId, month])
  @@index([month])
}

model TuitionPayment {
  id           String        @id @default(cuid())
  studentId    String
  student      Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date         DateTime
  amount       Int
  method       PaymentMethod
  comment      String?
  createdById  String
  createdBy    User          @relation("TuitionPaymentCreatedBy", fields: [createdById], references: [id])
  reversalOfId String?
  reversalOf   TuitionPayment?  @relation("TuitionPaymentReversal", fields: [reversalOfId], references: [id])
  reversals    TuitionPayment[] @relation("TuitionPaymentReversal")
  createdAt    DateTime      @default(now())

  @@index([studentId, date])
  @@index([date])
}

model TeacherRate {
  id          String   @id @default(cuid())
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  hourlyRate  Int
  validFrom   DateTime
  createdAt   DateTime @default(now())

  @@index([teacherId, validFrom])
}

model TeachingSessionDurationAdjustment {
  id                String          @id @default(cuid())
  teachingSessionId String          @unique
  teachingSession   TeachingSession @relation(fields: [teachingSessionId], references: [id], onDelete: Cascade)
  originalMinutes   Int
  adjustedMinutes   Int
  reason            String
  adjustedById      String
  adjustedBy        User            @relation("SessionDurationAdjustedBy", fields: [adjustedById], references: [id])
  createdAt         DateTime        @default(now())
}

model SalaryAccrual {
  id           String              @id @default(cuid())
  teacherId    String
  teacher      Teacher             @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  month        String
  totalMinutes Int
  amount       Int
  status       SalaryAccrualStatus @default(DRAFT)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  payouts      SalaryPayout[]

  @@unique([teacherId, month])
  @@index([month, status])
}

model SalaryPayout {
  id           String        @id @default(cuid())
  accrualId    String
  accrual      SalaryAccrual @relation(fields: [accrualId], references: [id], onDelete: Cascade)
  date         DateTime
  amount       Int
  method       PaymentMethod
  comment      String?
  createdById  String
  createdBy    User          @relation("SalaryPayoutCreatedBy", fields: [createdById], references: [id])
  reversalOfId String?
  reversalOf   SalaryPayout?  @relation("SalaryPayoutReversal", fields: [reversalOfId], references: [id])
  reversals    SalaryPayout[] @relation("SalaryPayoutReversal")
  createdAt    DateTime      @default(now())

  @@index([accrualId])
  @@index([date])
}

model Expense {
  id           String          @id @default(cuid())
  date         DateTime
  amount       Int
  category     ExpenseCategory
  method       PaymentMethod
  comment      String?
  createdById  String
  createdBy    User            @relation("ExpenseCreatedBy", fields: [createdById], references: [id])
  reversalOfId String?
  reversalOf   Expense?        @relation("ExpenseReversal", fields: [reversalOfId], references: [id])
  reversals    Expense[]       @relation("ExpenseReversal")
  createdAt    DateTime        @default(now())

  @@index([date])
}

model Donation {
  id           String        @id @default(cuid())
  date         DateTime
  amount       Int
  method       PaymentMethod
  comment      String?
  createdById  String
  createdBy    User          @relation("DonationCreatedBy", fields: [createdById], references: [id])
  reversalOfId String?
  reversalOf   Donation?     @relation("DonationReversal", fields: [reversalOfId], references: [id])
  reversals    Donation[]    @relation("DonationReversal")
  createdAt    DateTime      @default(now())

  @@index([date])
}

model MonthClose {
  id          String   @id @default(cuid())
  month       String   @unique
  closedAt    DateTime @default(now())
  closedById  String
  closedBy    User     @relation("MonthCloseCreatedBy", fields: [closedById], references: [id])
}

model AuditEvent {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  entityType String
  entityId   String
  payload    Json
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([entityType, entityId])
}

model LeaveRequest {
  id                  String             @id @default(cuid())
  teacherId           String
  teacher             Teacher            @relation("LeaveRequestTeacher", fields: [teacherId], references: [id])
  type                LeaveRequestType
  status              LeaveRequestStatus @default(CREATED)
  startDate           DateTime
  endDate             DateTime
  description         String
  rejectionReason     String?
  substituteTeacherId String?
  substituteTeacher   Teacher?           @relation("LeaveRequestSubstitute", fields: [substituteTeacherId], references: [id])
  substitutionId      String?            @unique
  substitution        Substitution?      @relation(fields: [substitutionId], references: [id])
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([teacherId, status])
  @@index([startDate, endDate])
}

model Substitution {
  id                  String   @id @default(cuid())
  absentTeacherId     String
  absentTeacher       Teacher  @relation("SubstitutionAbsent", fields: [absentTeacherId], references: [id])
  substituteTeacherId String
  substituteTeacher   Teacher  @relation("SubstitutionSubstitute", fields: [substituteTeacherId], references: [id])
  leaveRequestId      String?       @unique
  leaveRequest        LeaveRequest?
  startDate           DateTime
  endDate             DateTime
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([substituteTeacherId, isActive])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  link      String?
  payload   Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Conversation {
  id             String    @id @default(cuid())
  participant1Id String
  participant2Id String
  participant1   User      @relation("ConversationParticipant1", fields: [participant1Id], references: [id], onDelete: Cascade)
  participant2   User      @relation("ConversationParticipant2", fields: [participant2Id], references: [id], onDelete: Cascade)
  messages       Message[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([participant1Id, participant2Id])
  @@index([participant1Id])
  @@index([participant2Id])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body           String
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

model Post {
  id          String      @id @default(cuid())
  title       String
  body        Json
  authorId    String
  author      User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  publishedAt DateTime    @default(now())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  media       PostMedia[]
  likes       PostLike[]

  @@index([publishedAt])
}

model PostMedia {
  id        String        @id @default(cuid())
  postId    String
  post      Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  type      PostMediaType
  url       String
  sortOrder Int           @default(0)

  @@index([postId, sortOrder])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
}
