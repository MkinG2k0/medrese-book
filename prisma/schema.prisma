generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  MANAGER
  TEACHER
  STUDENT
}

enum Attendance {
  PRESENT
  LATE
  ABSENT
}

enum AwardType {
  STUDY
  ACTIVITY
}

model User {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  role      Role
  phone     String?
  teacher   Teacher?
  student   Student?
  createdAt DateTime @default(now())
}

model Teacher {
  id     String  @id @default(cuid())
  userId String  @unique
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  groups Group[]
}

model Group {
  id        String    @id @default(cuid())
  name      String
  teacherId String
  teacher   Teacher   @relation(fields: [teacherId], references: [id])
  students  Student[]
}

model Student {
  id             String           @id @default(cuid())
  userId         String           @unique
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName       String?
  phone          String?
  guardianPhone  String?
  groupId        String
  group          Group            @relation(fields: [groupId], references: [id])
  levelId        String
  level          Level            @relation(fields: [levelId], references: [id])
  currentStepIdx Int              @default(0)
  sessions       Session[]
  completions    StepCompletion[]
  awards         Award[]
}

model Level {
  id       String    @id @default(cuid())
  number   Int       @unique
  title    String
  students Student[]
  steps    Step[]
}

model Step {
  id          String           @id @default(cuid())
  levelId     String
  level       Level            @relation(fields: [levelId], references: [id], onDelete: Cascade)
  order       Int
  title       String
  content     Json
  description String           @default("")
  hours       Int
  completions StepCompletion[]

  @@unique([levelId, order])
}

model Session {
  id            String           @id @default(cuid())
  studentId     String
  student       Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date          DateTime
  attendance    Attendance
  lateMinutes   Int?
  note          String?
  isAdjustment  Boolean          @default(false)
  completions   StepCompletion[]
  createdAt     DateTime         @default(now())
}

model StepCompletion {
  id            String   @id @default(cuid())
  studentId     String
  stepId        String
  sessionId     String
  grade         Int
  note          String?
  isPriorCredit Boolean  @default(false)
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  step          Step     @relation(fields: [stepId], references: [id])
  session       Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
}

model Award {
  id        String    @id @default(cuid())
  studentId String
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type      AwardType
  title     String
  date      DateTime  @default(now())
}

model AuditEvent {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  entityType String
  entityId   String
  payload    Json
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([entityType, entityId])
}
