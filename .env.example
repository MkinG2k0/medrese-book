# NextAuth / Auth.js
AUTH_SECRET=generate-a-random-secret-here
# Локально: http://localhost:3000 | На проде: https://ваш-домен.ru (не оставлять localhost!)
NEXTAUTH_URL=http://localhost:3000

# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@host.neon.tech/medrese?sslmode=require

# Production seed (pnpm db:seed:prod) — только супер-админ, без демо-данных
SUPER_ADMIN_CODE=100001
