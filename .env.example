# NextAuth / Auth.js
AUTH_SECRET=generate-a-random-secret-here
# Локально: http://localhost:3000 | На проде: https://ваш-домен.ru (не оставлять localhost!)
NEXTAUTH_URL=http://localhost:3000

# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@host.neon.tech/medrese?sslmode=require

# Защита demo/e2e seed от случайного запуска на prod-БД (см. README)
# PRODUCTION_DATABASE_URL=postgresql://user:password@prod-host.neon.tech/medrese?sslmode=require
# SEED_BLOCKED_DB_HOSTS=prod-host.neon.tech
# ALLOW_DESTRUCTIVE_SEED=1  # только локально, если осознанно сбрасываете prod-снимок

# Production seed (pnpm db:seed:prod) — программа + супер-админ, без демо-данных
SUPER_ADMIN_CODE=100001

# S3 / объектное хранилище (опционально)
# Без этих переменных загрузки сохраняются локально в public/uploads
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-central-1
# S3_BUCKET=medrese-uploads
# Публичный URL для отдачи файлов (CDN или endpoint бакета)
# S3_PUBLIC_URL=https://medrese-uploads.s3.eu-central-1.amazonaws.com
# Кастомный endpoint для MinIO, Cloudflare R2 и т.п.
# S3_ENDPOINT=
# Префикс ключей в бакете (по умолчанию uploads)
# S3_PREFIX=uploads
